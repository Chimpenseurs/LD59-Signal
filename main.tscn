[sub_resource type="GDScript" id="GDScript_lquwl"]
script/source = "extends Camera2D

var initial_offset
var rand_activated = false

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	initial_offset = offset


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if rand_activated:
		self.offset.x = initial_offset.x + randf_range(-5, 5)
		self.offset.y = initial_offset.y + randf_range(-5, 5)

func random_position_activate(enabled):
	rand_activated = enabled
	if not enabled:
		self.offset = initial_offset
"

