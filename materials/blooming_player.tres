[gd_resource type="ShaderMaterial" format=3 uid="uid://dx1fjlf8t1sik"]

[sub_resource type="Shader" id="Shader_lquwl"]
code = "shader_type canvas_item;
render_mode blend_add;
uniform vec2 rect_size = vec2(.1, .1);
uniform float bness = 1.0;
uniform float fall_off_scale = 3.0;
uniform float b_offset = 0.0; 
void fragment() {
	vec2 uv = UV - vec2(.5);
	vec2 cloest_rect_point; 
	cloest_rect_point = uv; 
	vec2 cuv = uv;
	float d2c = length(cuv);
	COLOR.a = - log(d2c*fall_off_scale + b_offset) * bness; 
	COLOR.a = max(0, COLOR.a);
} 
 "

[resource]
shader = SubResource("Shader_lquwl")
shader_parameter/rect_size = Vector2(0.2, 0.2)
shader_parameter/bness = 1.0
shader_parameter/fall_off_scale = 3.0
shader_parameter/b_offset = 0.0
